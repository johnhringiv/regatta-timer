<?xml version="1.0" encoding="utf-8"?>
<!--
    Burgee (racing pennant, flying right) containing a stopwatch.
    All three pennant vertices sit exactly 30 units from the icon center (54,54),
    so the shape is optically centered inside circular launcher masks (safe zone r=33).
    Colors follow the johnhringiv.com burgee favicon: gold #F5C518 / green #0B6B3A.
    Stopwatch glyph from Bootstrap Icons (MIT) — https://icons.getbootstrap.com/icons/stopwatch/
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    <!-- pennant: hoist on the left, apex flying right -->
    <path
        android:pathData="M34,31 L34,77 L84,54 Z"
        android:fillColor="#F5C518"
        android:strokeColor="#0B6B3A"
        android:strokeWidth="4"
        android:strokeLineJoin="round" />
    <!-- stopwatch nudged down-left of centroid so the crown nub clears the sloping top edge -->
    <group
        android:scaleX="1.4"
        android:scaleY="1.4"
        android:translateX="37.3"
        android:translateY="42.9">
